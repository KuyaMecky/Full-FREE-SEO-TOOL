generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                @id @default(cuid())
  email            String                @unique
  password         String
  name             String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  audits           Audit[]
  googleAccount    GoogleAccount?
  gscProperties    GscProperty[]
  wpConnections    WordPressConnection[]
  contentDrafts    ContentDraft[]
  contentClusters  ContentCluster[]
  ownedTeams       Team[]               @relation("TeamOwner")
  teamMemberships  TeamMember[]
  assignedTasks    PropertyAssignment[] @relation("AssignedTo")
  createdTasks     PropertyAssignment[] @relation("AssignedBy")
  rankKeywords     RankKeyword[]
  pageSnapshots    PageSnapshot[]
  userSettings     UserSettings?
  cwvHistory       CwvHistory[]
  notifications    Notification[]
  alertRules       AlertRule[]
  apiKeys          ApiKey[]
  contentAutomations ContentAutomation[]
}

model GoogleAccount {
  id             String        @id @default(cuid())
  userId         String        @unique
  googleEmail    String
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime
  scope          String        @default("")
  connectedAt    DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties     GscProperty[]
}

model GscProperty {
  id                 String               @id @default(cuid())
  userId             String
  googleAccountId    String
  siteUrl            String
  permissionLevel    String               @default("")
  addedAt            DateTime             @default(now())
  autoRefresh        Boolean              @default(false)
  lastAutoRefresh    DateTime?
  googleAccount      GoogleAccount        @relation(fields: [googleAccountId], references: [id], onDelete: Cascade)
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots          GscSnapshot[]
  submissions        IndexSubmission[]
  contentDrafts      ContentDraft[]
  contentClusters    ContentCluster[]
  assignments        PropertyAssignment[]
  rankKeywords       RankKeyword[]
  pageSnapshots      PageSnapshot[]
  contentAutomations ContentAutomation[]

  @@unique([googleAccountId, siteUrl])
  @@index([userId])
}

model IndexSubmission {
  id                String      @id @default(cuid())
  userId            String
  propertyId        String
  url               String
  note              String      @default("")
  status            String      @default("pending")
  lastIndexVerdict  String?
  lastCoverageState String?
  lastFetchState    String?
  lastCrawlTime     DateTime?
  lastCheckedAt     DateTime?
  submittedAt       DateTime    @default(now())
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  property          GscProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, url])
  @@index([userId])
  @@index([propertyId])
}

model GscSnapshot {
  id               String      @id @default(cuid())
  propertyId       String
  rangeStart       DateTime
  rangeEnd         DateTime
  totalImpressions Int         @default(0)
  totalClicks      Int         @default(0)
  avgCtr           Float       @default(0)
  avgPosition      Float       @default(0)
  byDate           String      @default("[]")
  byQuery          String      @default("[]")
  byPage           String      @default("[]")
  suggestions      String      @default("null")
  fetchedAt        DateTime    @default(now())
  property         GscProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Audit {
  id               String        @id @default(cuid())
  userId           String
  domain           String
  country          String        @default("US")
  language         String        @default("en")
  businessType     String        @default("")
  goals            String        @default("[]")
  priorityPages    String        @default("[]")
  competitors      String        @default("[]")
  seedKeywords     String        @default("[]")
  cmsStack         String        @default("")
  maxPages         Int           @default(50)
  status           String        @default("pending")
  overallScore     Float?
  errorMessage     String?
  keywordReport    String?
  competitorReport String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  report           AuditReport?
  crawlResults     CrawlResult[]
  cwvResults       CwvResult[]
  findings         Finding[]

  @@index([userId])
}

model CwvResult {
  id                 String   @id @default(cuid())
  auditId            String
  url                String
  strategy           String
  performanceScore   Float?
  accessibilityScore Float?
  seoScore           Float?
  bestPracticesScore Float?
  lcpMs              Int?
  fcpMs              Int?
  clsScore           Float?
  inpMs              Int?
  ttfbMs             Int?
  speedIndex         Int?
  fieldData          String   @default("null")
  topIssues          String   @default("[]")
  fetchedAt          DateTime @default(now())
  audit              Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, url, strategy])
  @@index([auditId])
}

model CrawlResult {
  id              String   @id @default(cuid())
  auditId         String
  url             String
  statusCode      Int
  title           String   @default("")
  metaDescription String   @default("")
  canonical       String   @default("")
  h1              String   @default("")
  headings        String   @default("[]")
  links           String   @default("[]")
  images          String   @default("[]")
  structuredData  String   @default("[]")
  issues          String   @default("[]")
  responseTime    Int      @default(0)
  contentLength   Int      @default(0)
  robotsMeta      String   @default("")
  createdAt       DateTime @default(now())
  audit           Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
}

model Finding {
  id             String   @id @default(cuid())
  auditId        String
  category       String
  issue          String
  evidence       String   @default("")
  affectedUrls   String   @default("[]")
  severity       String
  impact         String   @default("")
  recommendedFix String   @default("")
  owner          String   @default("")
  effort         String   @default("")
  priority       Int      @default(0)
  createdAt      DateTime @default(now())
  audit          Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
}

model AuditReport {
  id                 String   @id @default(cuid())
  auditId            String   @unique
  executiveSummary   String   @default("{}")
  scorecard          String   @default("{}")
  roadmap            String   @default("{}")
  kpiPlan            String   @default("{}")
  actionItems        String   @default("[]")
  stakeholderSummary String   @default("")
  devTaskList        String   @default("[]")
  createdAt          DateTime @default(now())
  audit              Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String @default("")
}

model AlertRule {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String?
  name        String
  metric      String   // avg_position | ctr | impressions | rank_drop | deindex
  operator    String   // lt | gt | drops_by
  threshold   Float
  enabled     Boolean  @default(true)
  lastFiredAt DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  aiProvider   String?
  aiApiKey     String?
  aiModel      String?
  emailAlerts  Boolean  @default(false)
  alertEmail   String?
  rankDropThreshold Int @default(5)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CwvHistory {
  id                 String   @id @default(cuid())
  userId             String
  url                String
  strategy           String   @default("mobile")
  performanceScore   Float?
  lcpMs              Int?
  clsScore           Float?
  inpMs              Int?
  fcpMs              Int?
  ttfbMs             Int?
  recordedAt         DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, url])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String   @default("")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RankKeyword {
  id         String           @id @default(cuid())
  userId     String
  propertyId String
  keyword    String
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   GscProperty      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  snapshots  RankSnapshot[]

  @@unique([propertyId, keyword])
  @@index([userId])
  @@index([propertyId])
}

model RankSnapshot {
  id         String      @id @default(cuid())
  keywordId  String
  date       DateTime
  position   Float
  impressions Int        @default(0)
  clicks     Int         @default(0)
  ctr        Float       @default(0)
  keyword    RankKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([keywordId, date])
  @@index([keywordId])
}

model PageSnapshot {
  id              String      @id @default(cuid())
  userId          String
  propertyId      String
  url             String
  title           String      @default("")
  metaDescription String      @default("")
  h1              String      @default("")
  wordCount       Int         @default(0)
  internalLinks   Int         @default(0)
  externalLinks   Int         @default(0)
  rawData         String      @default("{}")
  takenAt         DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  property        GscProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId, url])
}

model Team {
  id          String               @id @default(cuid())
  name        String
  ownerId     String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  owner       User                 @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     TeamMember[]
  invites     TeamInvite[]
  assignments PropertyAssignment[]

  @@index([ownerId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model TeamInvite {
  id        String   @id @default(cuid())
  teamId    String
  email     String
  token     String   @unique @default(cuid())
  role      String   @default("member")
  status    String   @default("pending")
  expiresAt DateTime
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([token])
}

model PropertyAssignment {
  id           String      @id @default(cuid())
  teamId       String
  propertyId   String
  assignedToId String
  assignedById String
  title        String
  description  String      @default("")
  priority     String      @default("medium")
  status       String      @default("open")
  dueDate      DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  team         Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  property     GscProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  assignedTo   User        @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedBy   User        @relation("AssignedBy", fields: [assignedById], references: [id])

  @@index([teamId])
  @@index([assignedToId])
  @@index([propertyId])
}

model WordPressConnection {
  id          String                  @id @default(cuid())
  userId      String
  label       String                  @default("My WordPress Site")
  siteUrl     String
  username    String
  appPassword String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  user        User                    @relation(fields: [userId], references: [id])
  drafts      ContentDraft[]
  automations ContentAutomation[]
}

model ContentCluster {
  id          String         @id @default(cuid())
  userId      String
  propertyId  String
  name        String
  pillarTopic String
  createdAt   DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id])
  property    GscProperty    @relation(fields: [propertyId], references: [id])
  drafts      ContentDraft[]
}

model ContentDraft {
  id               String               @id @default(cuid())
  userId           String
  propertyId       String
  clusterId        String?
  wpConnectionId   String?
  title            String
  slug             String
  metaTitle        String
  metaDescription  String
  focusKeyword     String
  content          String
  schemaMarkup     String?
  internalLinks    String               @default("[]")
  imageSuggestions String               @default("[]")
  status           String               @default("draft")
  scheduledAt      DateTime?
  wpPostId         Int?
  gscSignals       String               @default("{}")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User                 @relation(fields: [userId], references: [id])
  property         GscProperty          @relation(fields: [propertyId], references: [id])
  cluster          ContentCluster?      @relation(fields: [clusterId], references: [id])
  wpConnection     WordPressConnection? @relation(fields: [wpConnectionId], references: [id])
  generatedIdeas   GeneratedContentIdea[] @relation("DraftIdeas")
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  prefix      String    @unique
  keyHash     String    @unique
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, prefix])
}

model ContentAutomation {
  id                String                  @id @default(cuid())
  userId            String
  propertyId        String
  enabled           Boolean                 @default(true)
  autoGenerateIdeas Boolean                 @default(true)
  autoDraftIdeas    Boolean                 @default(true)
  autoWriteContent  Boolean                 @default(true)
  autoSchedulePublish Boolean               @default(false)
  maxDraftsPerRun   Int                     @default(5)
  scheduledDayOfWeek Int?                   // 0=Sunday, 6=Saturday
  scheduledHourUtc  Int?                    // 0-23
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  businessType      String                  @default("")
  seedTopics        String                  @default("[]")
  wpConnectionId    String?
  scheduleAfterDays Int                     @default(7)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  property          GscProperty             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  wpConnection      WordPressConnection?    @relation(fields: [wpConnectionId], references: [id], onDelete: SetNull)
  logs              AutomationLog[]
  ideas             GeneratedContentIdea[]

  @@unique([propertyId])
  @@index([userId])
}

model GeneratedContentIdea {
  id                String              @id @default(cuid())
  automationId      String
  title             String
  targetKeyword     String
  intent            String
  difficulty        String
  outline           String              @default("[]")
  rationale         String
  estimatedWordCount Int
  suggestedSlug     String
  internalLinkTargets String            @default("[]")
  draftId           String?
  status            String              @default("pending") // pending, draft_created, written, scheduled, published
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  automation        ContentAutomation   @relation(fields: [automationId], references: [id], onDelete: Cascade)
  draft             ContentDraft?       @relation("DraftIdeas", fields: [draftId], references: [id], onDelete: SetNull)

  @@index([automationId])
  @@index([status])
}

model AutomationLog {
  id                String              @id @default(cuid())
  automationId      String
  runType           String              // "ideas_generated", "drafts_created", "content_written", "publish_scheduled"
  status            String              // "success", "partial", "failed"
  itemsProcessed    Int                 @default(0)
  itemsFailed       Int                 @default(0)
  message           String              @default("")
  errorDetails      String              @default("[]")
  duration          Int                 @default(0)
  createdAt         DateTime            @default(now())
  automation        ContentAutomation   @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId, createdAt])
}
