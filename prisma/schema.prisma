generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                @id @default(cuid())
  email            String                @unique
  password         String?
  name             String?
  oauthProvider    String?
  oauthId          String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  audits           Audit[]
  googleAccount    GoogleAccount?
  gscProperties    GscProperty[]
  wpConnections    WordPressConnection[]
  contentDrafts    ContentDraft[]
  contentClusters  ContentCluster[]
  ownedTeams       Team[]               @relation("TeamOwner")
  teamMemberships  TeamMember[]
  assignedTasks    PropertyAssignment[] @relation("AssignedTo")
  createdTasks     PropertyAssignment[] @relation("AssignedBy")
  rankKeywords     RankKeyword[]
  pageSnapshots    PageSnapshot[]
  userSettings     UserSettings?
  cwvHistory       CwvHistory[]
  notifications      Notification[]
  alertRules         AlertRule[]
  apiKeys            ApiKey[]
  contentAutomations ContentAutomation[]
  webhooks           Webhook[]
  keywordData        KeywordData[]          @relation("KeywordData")
  competitorData     CompetitorData[]       @relation("CompetitorData")
  contentPerformance ContentPerformance[]   @relation("ContentPerformance")
  bulkOperations     BulkOperation[]
  healthScores       SEOHealthScore[]
  progressMetrics    ProgressMetric[]
}

model GoogleAccount {
  id             String        @id @default(cuid())
  userId         String        @unique
  googleEmail    String
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime
  scope          String        @default("")
  connectedAt    DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties     GscProperty[]
}

model GscProperty {
  id                 String               @id @default(cuid())
  userId             String
  googleAccountId    String
  siteUrl            String
  permissionLevel    String               @default("")
  addedAt            DateTime             @default(now())
  autoRefresh        Boolean              @default(false)
  lastAutoRefresh    DateTime?
  googleAccount      GoogleAccount        @relation(fields: [googleAccountId], references: [id], onDelete: Cascade)
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots          GscSnapshot[]
  submissions        IndexSubmission[]
  contentDrafts      ContentDraft[]
  contentClusters    ContentCluster[]
  assignments        PropertyAssignment[]
  rankKeywords       RankKeyword[]
  pageSnapshots      PageSnapshot[]
  contentAutomations ContentAutomation[]

  @@unique([googleAccountId, siteUrl])
  @@index([userId])
}

model IndexSubmission {
  id                String      @id @default(cuid())
  userId            String
  propertyId        String
  url               String
  note              String      @default("")
  status            String      @default("pending")
  lastIndexVerdict  String?
  lastCoverageState String?
  lastFetchState    String?
  lastCrawlTime     DateTime?
  lastCheckedAt     DateTime?
  submittedAt       DateTime    @default(now())
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  property          GscProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, url])
  @@index([userId])
  @@index([propertyId])
}

model GscSnapshot {
  id               String      @id @default(cuid())
  propertyId       String
  rangeStart       DateTime
  rangeEnd         DateTime
  totalImpressions Int         @default(0)
  totalClicks      Int         @default(0)
  avgCtr           Float       @default(0)
  avgPosition      Float       @default(0)
  byDate           String      @default("[]")
  byQuery          String      @default("[]")
  byPage           String      @default("[]")
  suggestions      String      @default("null")
  fetchedAt        DateTime    @default(now())
  property         GscProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Audit {
  id               String        @id @default(cuid())
  userId           String
  domain           String
  country          String        @default("US")
  language         String        @default("en")
  businessType     String        @default("")
  goals            String        @default("[]")
  priorityPages    String        @default("[]")
  competitors      String        @default("[]")
  seedKeywords     String        @default("[]")
  cmsStack         String        @default("")
  maxPages         Int           @default(50)
  status           String        @default("pending")
  overallScore     Float?
  errorMessage     String?
  keywordReport    String?
  competitorReport String?
  crawlProgress    String        @default("{}")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  report                AuditReport?
  crawlResults          CrawlResult[]
  cwvResults            CwvResult[]
  findings              Finding[]
  recommendations       SEORecommendation[]
  competitorAnalysis    CompetitorData[]        @relation("CompetitorAnalysis")
  contentPerformance    ContentPerformance[]    @relation("ContentPerformance")
  issueImpactScores     IssueImpactScore[]      @relation("IssueImpactScores")
  bulkOperations        BulkOperation[]
  healthScores          SEOHealthScore[]
  progressMetrics       ProgressMetric[]

  @@index([userId])
}

model CwvResult {
  id                 String   @id @default(cuid())
  auditId            String
  url                String
  strategy           String
  performanceScore   Float?
  accessibilityScore Float?
  seoScore           Float?
  bestPracticesScore Float?
  lcpMs              Int?
  fcpMs              Int?
  clsScore           Float?
  inpMs              Int?
  ttfbMs             Int?
  speedIndex         Int?
  fieldData          String   @default("null")
  topIssues          String   @default("[]")
  fetchedAt          DateTime @default(now())
  audit              Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, url, strategy])
  @@index([auditId])
}

model CrawlResult {
  id              String   @id @default(cuid())
  auditId         String
  url             String
  statusCode      Int
  title           String   @default("")
  metaDescription String   @default("")
  canonical       String   @default("")
  h1              String   @default("")
  headings        String   @default("[]")
  links           String   @default("[]")
  images          String   @default("[]")
  structuredData  String   @default("[]")
  issues          String   @default("[]")
  responseTime    Int      @default(0)
  contentLength   Int      @default(0)
  robotsMeta      String   @default("")
  createdAt       DateTime @default(now())
  audit           Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
}

model Finding {
  id             String   @id @default(cuid())
  auditId        String
  category       String
  issue          String
  evidence       String   @default("")
  affectedUrls   String   @default("[]")
  severity       String
  impact         String   @default("")
  recommendedFix String   @default("")
  owner          String   @default("")
  effort         String   @default("")
  priority       Int      @default(0)
  createdAt      DateTime @default(now())
  audit          Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
}

model AuditReport {
  id                 String   @id @default(cuid())
  auditId            String   @unique
  executiveSummary   String   @default("{}")
  scorecard          String   @default("{}")
  roadmap            String   @default("{}")
  kpiPlan            String   @default("{}")
  actionItems        String   @default("[]")
  stakeholderSummary String   @default("")
  devTaskList        String   @default("[]")
  shareSlug          String?  @unique
  isShared           Boolean  @default(false)
  viewCount          Int      @default(0)
  lastViewedAt       DateTime?
  expiresAt          DateTime?
  createdAt          DateTime @default(now())
  audit              Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([shareSlug])
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String @default("")
}

model AlertRule {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String?
  name        String
  metric      String   // avg_position | ctr | impressions | rank_drop | deindex
  operator    String   // lt | gt | drops_by
  threshold   Float
  enabled     Boolean  @default(true)
  lastFiredAt DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  aiProvider        String?
  aiApiKey          String?
  aiModel           String?
  emailAlerts       Boolean  @default(false)
  alertEmail        String?
  rankDropThreshold Int      @default(5)
  ahrefsApiKey      String?
  pagespeedApiKey   String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CwvHistory {
  id                 String   @id @default(cuid())
  userId             String
  url                String
  strategy           String   @default("mobile")
  performanceScore   Float?
  lcpMs              Int?
  clsScore           Float?
  inpMs              Int?
  fcpMs              Int?
  ttfbMs             Int?
  recordedAt         DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, url])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String   @default("")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RankKeyword {
  id         String           @id @default(cuid())
  userId     String
  propertyId String
  keyword    String
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   GscProperty      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  snapshots  RankSnapshot[]

  @@unique([propertyId, keyword])
  @@index([userId])
  @@index([propertyId])
}

model RankSnapshot {
  id         String      @id @default(cuid())
  keywordId  String
  date       DateTime
  position   Float
  impressions Int        @default(0)
  clicks     Int         @default(0)
  ctr        Float       @default(0)
  keyword    RankKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([keywordId, date])
  @@index([keywordId])
}

model PageSnapshot {
  id              String      @id @default(cuid())
  userId          String
  propertyId      String
  url             String
  title           String      @default("")
  metaDescription String      @default("")
  h1              String      @default("")
  wordCount       Int         @default(0)
  internalLinks   Int         @default(0)
  externalLinks   Int         @default(0)
  rawData         String      @default("{}")
  takenAt         DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  property        GscProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId, url])
}

model Team {
  id          String               @id @default(cuid())
  name        String
  ownerId     String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  owner       User                 @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     TeamMember[]
  invites     TeamInvite[]
  assignments PropertyAssignment[]

  @@index([ownerId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model TeamInvite {
  id        String   @id @default(cuid())
  teamId    String
  email     String
  token     String   @unique @default(cuid())
  role      String   @default("member")
  status    String   @default("pending")
  expiresAt DateTime
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([token])
}

model PropertyAssignment {
  id           String      @id @default(cuid())
  teamId       String
  propertyId   String
  assignedToId String
  assignedById String
  title        String
  description  String      @default("")
  priority     String      @default("medium")
  status       String      @default("open")
  dueDate      DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  team         Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  property     GscProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  assignedTo   User        @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedBy   User        @relation("AssignedBy", fields: [assignedById], references: [id])

  @@index([teamId])
  @@index([assignedToId])
  @@index([propertyId])
}

model WordPressConnection {
  id          String                  @id @default(cuid())
  userId      String
  label       String                  @default("My WordPress Site")
  siteUrl     String
  username    String
  appPassword String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  user        User                    @relation(fields: [userId], references: [id])
  drafts      ContentDraft[]
  automations ContentAutomation[]
}

model ContentCluster {
  id          String         @id @default(cuid())
  userId      String
  propertyId  String
  name        String
  pillarTopic String
  createdAt   DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id])
  property    GscProperty    @relation(fields: [propertyId], references: [id])
  drafts      ContentDraft[]
}

model ContentDraft {
  id               String               @id @default(cuid())
  userId           String
  propertyId       String
  clusterId        String?
  wpConnectionId   String?
  title            String
  slug             String
  metaTitle        String
  metaDescription  String
  focusKeyword     String
  content          String
  schemaMarkup     String?
  internalLinks    String               @default("[]")
  imageSuggestions String               @default("[]")
  status           String               @default("draft")
  scheduledAt      DateTime?
  wpPostId         Int?
  gscSignals       String               @default("{}")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User                 @relation(fields: [userId], references: [id])
  property         GscProperty          @relation(fields: [propertyId], references: [id])
  cluster          ContentCluster?      @relation(fields: [clusterId], references: [id])
  wpConnection     WordPressConnection? @relation(fields: [wpConnectionId], references: [id])
  generatedIdeas   GeneratedContentIdea[] @relation("DraftIdeas")
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  prefix      String    @unique
  keyHash     String    @unique
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, prefix])
}

model ContentAutomation {
  id                String                  @id @default(cuid())
  userId            String
  propertyId        String
  enabled           Boolean                 @default(true)
  autoGenerateIdeas Boolean                 @default(true)
  autoDraftIdeas    Boolean                 @default(true)
  autoWriteContent  Boolean                 @default(true)
  autoSchedulePublish Boolean               @default(false)
  maxDraftsPerRun   Int                     @default(5)
  scheduledDayOfWeek Int?                   // 0=Sunday, 6=Saturday
  scheduledHourUtc  Int?                    // 0-23
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  businessType      String                  @default("")
  seedTopics        String                  @default("[]")
  wpConnectionId    String?
  scheduleAfterDays Int                     @default(7)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  property          GscProperty             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  wpConnection      WordPressConnection?    @relation(fields: [wpConnectionId], references: [id], onDelete: SetNull)
  logs              AutomationLog[]
  ideas             GeneratedContentIdea[]

  @@unique([propertyId])
  @@index([userId])
}

model GeneratedContentIdea {
  id                String              @id @default(cuid())
  automationId      String
  title             String
  targetKeyword     String
  intent            String
  difficulty        String
  outline           String              @default("[]")
  rationale         String
  estimatedWordCount Int
  suggestedSlug     String
  internalLinkTargets String            @default("[]")
  draftId           String?
  status            String              @default("pending") // pending, draft_created, written, scheduled, published
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  automation        ContentAutomation   @relation(fields: [automationId], references: [id], onDelete: Cascade)
  draft             ContentDraft?       @relation("DraftIdeas", fields: [draftId], references: [id], onDelete: SetNull)

  @@index([automationId])
  @@index([status])
}

model AutomationLog {
  id                String              @id @default(cuid())
  automationId      String
  runType           String              // "ideas_generated", "drafts_created", "content_written", "publish_scheduled"
  status            String              // "success", "partial", "failed"
  itemsProcessed    Int                 @default(0)
  itemsFailed       Int                 @default(0)
  message           String              @default("")
  errorDetails      String              @default("[]")
  duration          Int                 @default(0)
  createdAt         DateTime            @default(now())
  automation        ContentAutomation   @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId, createdAt])
}

model Webhook {
  id          String    @id @default(cuid())
  userId      String
  name        String
  url         String
  event       String    // "audit_complete", "findings_generated", etc.
  active      Boolean   @default(true)
  secret      String?   // For HMAC signature verification
  headers     String    @default("{}")  // Custom headers as JSON
  lastFiredAt DateTime?
  lastError   String?
  failCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, event])
  @@index([active])
}

// SEO Intelligence Features - Phase 1 Foundation

model SEORecommendation {
  id              String   @id @default(cuid())
  auditId         String
  findingId       String?
  category        String   // "content", "technical", "authority", "ux"
  title           String
  description     String   @db.Text
  actionPlan      String   @db.Text  // Step-by-step implementation guide
  estimatedImpact String   // "high", "medium", "low"
  impactMetric    String   // e.g., "+15-20% organic traffic"
  timeInvestment  String   // e.g., "2-4 hours"
  priority        Int      // 1-10 priority score
  relatedKeywords String   @default("[]")  // JSON array of keywords
  implementation  String   @default("{}")  // Implementation guide as JSON
  status          String   @default("pending")  // "pending", "in_progress", "completed"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  audit           Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId, status])
  @@index([priority, estimatedImpact])
}

model KeywordData {
  id              String   @id @default(cuid())
  userId          String
  auditId         String?
  keyword         String
  searchVolume    Int?     // Monthly search volume
  difficulty      Float?   // 0-100 difficulty score
  intent          String?  // "commercial", "informational", "navigational", "transactional"
  trend           String   @default("{}")  // Google Trends data as JSON
  cpc             Float?   // Cost per click estimate
  relatedKeywords String   @default("[]")  // Related keywords JSON
  ranking         Int?     // Current ranking position
  rankingUrl      String?
  clicks          Int?     // Monthly clicks from this keyword
  impressions     Int?     // Monthly impressions
  ctr             Float?   // Click-through rate
  lastUpdated     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation("KeywordData", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, keyword, auditId])
  @@index([userId, searchVolume])
  @@index([userId, ranking])
}

model CompetitorData {
  id                String   @id @default(cuid())
  auditId           String
  userId            String
  competitorDomain  String
  keywords          String   @default("[]")  // Keywords they rank for (JSON)
  topPages          String   @default("[]")  // Their best performing pages (JSON)
  estimatedTraffic  Int?     // Estimated monthly traffic
  dominatingTopics  String   @default("[]")  // Topics they dominate (JSON)
  contentGaps       String   @default("[]")  // Opportunities we have (JSON)
  backlinks         Int?     // Number of backlinks
  dominatingDomains String   @default("[]")  // Where they get backlinks from (JSON)
  lastAnalyzed      DateTime @default(now())
  analysisData      String   @default("{}")  // Full analysis as JSON
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation("CompetitorData", fields: [userId], references: [id], onDelete: Cascade)
  audit             Audit    @relation("CompetitorAnalysis", fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, competitorDomain])
  @@index([userId, competitorDomain])
}

model ContentPerformance {
  id                String   @id @default(cuid())
  auditId           String
  userId            String
  url               String
  title             String?
  keywords          String   @default("[]")  // Keywords ranking (JSON)
  organicTraffic    Int?     // Monthly organic traffic
  keywordCount      Int?     // Number of keywords ranking
  topKeyword        String?  // Best performing keyword
  topKeywordRank    Int?     // Ranking of top keyword
  contentLength     Int?     // Word count
  readabilityScore  Float?   // Flesch reading ease
  engagementScore   Float?   // Based on available metrics
  performanceScore  Float?   // PageSpeed score
  lastAnalyzed      DateTime @default(now())
  trend             String   @default("{}")  // Performance trend data JSON
  recommendations   String   @default("[]")  // Content improvement tips (JSON)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation("ContentPerformance", fields: [userId], references: [id], onDelete: Cascade)
  audit             Audit    @relation("ContentPerformance", fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, url])
  @@index([userId, organicTraffic])
  @@index([userId, contentLength])
}

model IssueImpactScore {
  id              String   @id @default(cuid())
  findingId       String
  auditId         String
  issueType       String   // Type of issue
  severityScore   Float    // 0-10 severity
  impactScore     Float    // 0-10 potential traffic impact
  affectedPages   Int      // Number of pages affected
  estimatedTraffic Int     // Estimated traffic impact in clicks/month
  fixComplexity   Float    // 0-10 effort to fix
  priorityScore   Float    // Combined priority score
  reasoning       String   @db.Text // Why this score was assigned
  calculatedAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  audit           Audit    @relation("IssueImpactScores", fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([findingId])
  @@index([auditId, priorityScore])
}

model BulkOperation {
  id               String   @id @default(cuid())
  auditId          String
  userId           String
  operationType    String   // Type of bulk operation (update-meta-title, add-schema-markup, etc.)
  pagesAffected    Int      // Number of pages targeted
  successCount     Int      // Successfully processed pages
  failureCount     Int      // Failed pages
  estimatedImpact  Int      // Estimated traffic impact in clicks/month
  result           String   @db.Text  // Detailed results as JSON
  status           String   @default("completed")  // completed, in_progress, failed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  audit            Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([auditId, createdAt])
  @@index([userId, createdAt])
}

model SEOHealthScore {
  id                    String   @id @default(cuid())
  auditId               String
  userId                String
  overallScore          Float    // 0-100 overall health score
  issueScore            Float    // Based on issue count and severity (0-100)
  contentScore          Float    // Based on content quality metrics (0-100)
  technicalScore        Float    // Based on crawlability and indexing (0-100)
  performanceScore      Float    // Based on Core Web Vitals (0-100)
  keywordScore          Float    // Based on keyword rankings (0-100)
  issueCount            Int      // Total issues found
  criticalIssues        Int      // Critical severity issues
  highIssues            Int      // High severity issues
  mediumIssues          Int      // Medium severity issues
  estimatedTrafficLoss  Int      // Estimated lost traffic in clicks/month
  estimatedFixes        Int      // Estimated traffic recovery available
  quickWinsAvailable    Int      // Number of high-impact low-effort fixes
  averageFixTime        Int      // Average hours to implement fixes
  reasoning             String   @db.Text  // Why the score is what it is
  recordedAt            DateTime @default(now())
  createdAt             DateTime @default(now())
  audit                 Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([auditId, recordedAt])
  @@index([userId, recordedAt])
  @@index([auditId, createdAt])
}

model ProgressMetric {
  id                    String   @id @default(cuid())
  auditId               String
  userId                String
  metricType            String   // "issue_fixed", "ranking_improved", "traffic_gained", etc.
  baseline              Int      // Baseline value (e.g., initial ranking position)
  current               Int      // Current value
  improvement           Int      // Absolute improvement
  percentImprovement    Float    // Percentage improvement
  estimatedImpact       Int      // Estimated traffic impact
  affectedPages         Int      // Number of pages affected
  daysToResult          Int      // Days since fix was applied
  status                String   @default("in_progress")  // in_progress, achieved, pending
  details               String   @default("{}")  // Additional metadata as JSON
  recordedAt            DateTime @default(now())
  createdAt             DateTime @default(now())
  audit                 Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([auditId, metricType])
  @@index([userId, recordedAt])
}

